{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["src/ambire-common/src/*"],
      "@test/*": ["src/ambire-common/test/*"],
      "@ambire-common/*": ["src/ambire-common/src/*"],
      "@contracts/*": ["src/ambire-common/contracts/*"],
      "@ambire-common-v1/*": ["src/ambire-common/v1/*"],
      "@common/*": ["src/common/*"],
      "@mobile/*": ["src/mobile/*"],
      "@web/*": ["src/web/*"],
      "@benzin/*": ["src/benzin/*"],
      "@legends/*": ["src/legends/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "ios",
    "android",
    "safari-extension",
    "build",
    "coverage",
    ".expo",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "index.js",
    "src/ambire-common/**/*",
    "src/benzin/**/*",
    "src/legends/**/*",
    "e2e-playwright-tests/**/*"
  ]
}
