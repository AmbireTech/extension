# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY: use Node from project .nvmrc so everyone get the same version.
# Xcode runs this file with /bin/sh; nvm is bash-only, so we resolve the node path in a
# bash subshell. When building Pods, SRCROOT can be the Pods dir — so we also check
# PODS_ROOT/../.. for project root (.nvmrc).
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
_project_root=""
if [ -n "${SRCROOT:-}" ] && [ -f "$SRCROOT/../.nvmrc" ]; then
  _project_root="$SRCROOT/.."
elif [ -n "${PODS_ROOT:-}" ] && [ -f "$PODS_ROOT/../../.nvmrc" ]; then
  _project_root="$PODS_ROOT/../.."
fi
if [ -s "$NVM_DIR/nvm.sh" ] && [ -n "$_project_root" ]; then
  _node_path=$(bash -l -c 'export NVM_DIR="'"$NVM_DIR"'"; \. "$NVM_DIR/nvm.sh" --no-use; cd "'"$_project_root"'" && nvm use >/dev/null 2>&1; command -v node')
  if [ -n "$_node_path" ] && [ -x "$_node_path" ]; then
    export NODE_BINARY="$_node_path"
  fi
  unset _node_path
fi
unset _project_root
if [ -z "${NODE_BINARY:-}" ]; then
  _fallback=$(command -v node)
  if [ -n "$_fallback" ] && [ -x "$_fallback" ]; then
    export NODE_BINARY="$_fallback"
  fi
  unset _fallback
fi
