<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Ambire</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <!-- This is planned to be in sync with app.json 's "version" two components, e.g. 5.39 -->
    <key>CFBundleShortVersionString</key>
    <string>6.14</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleURLTypes</key>
    <array>
      <dict>
        <key>CFBundleURLSchemes</key>
        <array>
          <string>ambire</string>
          <string>wc</string>
          <string>ethereum</string>
        </array>
      </dict>
    </array>
    <key>CFBundleVersion</key>
    <string>66</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>LSApplicationQueriesSchemes</key>
    <array>
      <string>imtokenv2</string>
      <string>tpoutside</string>
      <string>rainbow</string>
      <string>bitkeep</string>
      <string>trust</string>
      <string>argent</string>
      <string>metamask</string>
      <string>mathwallet</string>
      <string>zerion</string>
      <string>cbwallet</string>
      <string>blob</string>
      <string>rabby</string>
      <string>rabbymobile</string>
    </array>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
      <key>NSAllowsArbitraryLoads</key>
      <false/>
      <key>NSAllowsLocalNetworking</key>
      <true/>
    </dict>
    <key>NSCameraUsageDescription</key>
    <string>$(PRODUCT_NAME) needs access to your Camera to scan QR codes.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>$(PRODUCT_NAME) needs access to your Photo Library to import and read QR codes from images.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>Allow $(PRODUCT_NAME) to use Face ID</string>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>$(PRODUCT_NAME) needs Bluetooth access to connect to your Ledger hardware wallet.</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <key>RCTNewArchEnabled</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>SplashScreen</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
      <string>arm64</string>
    </array>
    <key>UIRequiresFullScreen</key>
    <true/>
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
      <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UIUserInterfaceStyle</key>
    <string>Automatic</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    <key>StallionProjectId</key>
    <string>__STALLION_PROJECT_ID__</string>
    <key>StallionAppToken</key>
    <string>__STALLION_APP_TOKEN__</string>
    <key>StallionPublicSigningKey</key>
    <string>__STALLION_PUBLIC_SIGNING_KEY__</string>
    <!-- Fonts are embedded natively (registered at launch), NOT loaded at runtime from the JS
         bundle. This keeps them independent of the Stallion OTA bundle slot, which otherwise
         breaks font application for text rendered after an OTA download/restart. Paths are
         relative to the `fonts` folder reference copied into the app bundle. -->
    <key>UIAppFonts</key>
    <array>
      <string>fonts/Poppins-Light.ttf</string>
      <string>fonts/Poppins-Regular.ttf</string>
      <string>fonts/Poppins-Medium.ttf</string>
      <string>fonts/Poppins-SemiBold.ttf</string>
      <string>fonts/Roboto-Light.ttf</string>
      <string>fonts/Roboto-Regular.ttf</string>
      <string>fonts/Roboto-Medium.ttf</string>
      <string>fonts/Roboto-Bold.ttf</string>
      <string>fonts/Roboto-Black.ttf</string>
      <string>fonts/GeistMono-Regular.ttf</string>
    </array>
  </dict>
</plist>
